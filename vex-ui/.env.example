# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# ── better-auth ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── GitHub App (for Octokit API calls: teams, GHA dispatch, Git Data API) ────
# Personal access token with: read:org, repo, workflow
GITHUB_TOKEN=""

# ── Signing ──────────────────────────────────────────────────────────────────
# HMAC secret shared with GHA org secret VEX_UI_SIGNING_SECRET
SIGNING_CALLBACK_SECRET="generate-with: openssl rand -base64 32"

# ── VEX Filesystem Paths (absolute) ─────────────────────────────────────────
# These can also be configured via Admin → Settings in the UI
VEX_REPO_SRC_PATH="E:/development/projects/vex/trivy-vex-demo/vex-repo-src"
VEX_REPO_DIR_PATH="E:/development/projects/vex/trivy-vex-demo/vex-repo"
VEX_STATEMENTS_PATH="E:/development/projects/vex/trivy-vex-demo/vex/statements"

# ── GitHub Org + Pages ───────────────────────────────────────────────────────
GITHUB_ORG="darkedges"
GH_PAGES_REPO="darkedges/trivy-vex-demo"
GH_PAGES_BRANCH="gh-pages"

# ── VEX Document Base URL ────────────────────────────────────────────────────
VEX_DOC_BASE_URL="https://darkedges.com/vex"
VEX_REPO_PUBLIC_URL="https://darkedges.github.io/trivy-vex-demo"

# ── App URL (used for signing callback) ─────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
